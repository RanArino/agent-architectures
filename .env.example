# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env
#
# `.env` is gitignored, so your real key never gets committed.
# Real shell environment variables (e.g. `export OPENAI_API_KEY=...`) take
# precedence over this file if both are set.

# Required for live architecture runs (the `tasks` command and the test suite
# need no key). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional. Defaults to gpt-4.1-mini. Cost is shown as n/a for any model the
# PoC has no published rate for.
# OPENAI_MODEL=gpt-4.1-mini

# Optional. Override the local UI bind host/port (defaults: 127.0.0.1:8000).
# AGENTFLOW_UI_HOST=127.0.0.1
# AGENTFLOW_UI_PORT=8000
